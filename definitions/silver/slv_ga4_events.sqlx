config { 
  type: "table", 
  schema: data.silver_schema,
  name: data.tab_slv_ga4 
}
SELECT
  parse_date('%Y%m%d', event_date) AS data,
  event_name,
  (SELECT value.int_value FROM UNNEST(event_params) WHERE key = 'ga_session_id') AS session_id,
  traffic_source.name AS campanha
FROM `${data.project_id}.${data.raw_ga4}.events_*`