config { 
  type: "table", 
  schema: data.gold_schema,
  name: data.tab_gld_retail,
  disabled: !data.enable_retail_media 
}
SELECT
  data,
  campanha,
  REGEXP_EXTRACT(campanha, r'\[(.*?)\]') AS categoria,
  SUM(cliques) AS cliques,
  SUM(custo) AS custo
FROM ${ref(data.tab_slv_ads)}
GROUP BY 1,2,3